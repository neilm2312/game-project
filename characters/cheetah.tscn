script/source = "extends CharacterBody2D

enum State { IDLE, STALKING, WINDUP, POUNCING, CHASING }

# --- Settings ---
@export var stalk_speed = 80.0
@export var chase_speed = 350.0
@export var pounce_speed = 600.0
@export var pounce_range = 150.0
@export var detection_range = 400.0
@export var pounce_trigger_range = 150.0
@export var windup_time = 0.6
@export var max_stamina = 3.0
@export var stamina_recovery = 0.5

# --- State ---
var state = State.IDLE
var pounce_direction = Vector2.ZERO
var pounce_distance_traveled = 0.0
var stamina = 0.0
var player = null

@onready var anim = $AnimatedSprite2D
@onready var windup_timer = $WindupTimer
@onready var stun_timer = $StunTimer
@onready var detection_area = $DetectionArea
@onready var detection_shape = $DetectionArea/CollisionShape2D
@onready var pounce_area = $PounceArea
@onready var pounce_shape = $PounceArea/CollisionShape2D

func _ready():
	# size detection shapes from export variables
	var outer = CircleShape2D.new()
	outer.radius = detection_range
	detection_shape.shape = outer

	var inner = CircleShape2D.new()
	inner.radius = pounce_trigger_range
	pounce_shape.shape = inner

	# connect timers
	windup_timer.wait_time = windup_time
	windup_timer.one_shot = true
	stun_timer.one_shot = true
	windup_timer.timeout.connect(_on_windup_timeout)
	stun_timer.timeout.connect(_on_stun_timeout)

	# connect detection signals
	detection_area.body_entered.connect(_on_detection_entered)
	detection_area.body_exited.connect(_on_detection_exited)
	pounce_area.body_entered.connect(_on_pounce_range_entered)

	stamina = max_stamina
	print(\"Cheetah ready\")
	set_state(State.IDLE)

func _physics_process(delta):
	match state:
		State.IDLE:
			velocity = Vector2.ZERO
			# recover stamina while idle
			stamina = min(stamina + stamina_recovery * delta, max_stamina)

		State.STALKING:
			# recover stamina while stalking
			stamina = min(stamina + stamina_recovery * delta, max_stamina)
			if player != null:
				var dir = (player.global_position - global_position).normalized()
				velocity = dir * stalk_speed

		State.WINDUP:
			velocity = Vector2.ZERO

		State.POUNCING:
			velocity = pounce_direction * pounce_speed
			move_and_slide()
			pounce_distance_traveled += pounce_speed * delta

			# hit something — stop
			if get_slide_collision_count() > 0:
				set_state(State.IDLE)
				return

			# missed — start chasing
			if pounce_distance_traveled >= pounce_range:
				set_state(State.CHASING)
			return

		State.CHASING:
			if player != null:
				var dir = (player.global_position - global_position).normalized()
				velocity = dir * chase_speed

			# drain stamina
			stamina -= delta
			if stamina <= 0.0:
				print(\"Cheetah out of stamina\")
				set_state(State.IDLE)
				return

			# give up if player leaves detection range
			if player == null:
				set_state(State.IDLE)
				return

	move_and_slide()

# --- Timer callbacks ---
func _on_windup_timeout():
	if player != null:
		pounce_direction = (player.global_position - global_position).normalized()
	set_state(State.POUNCING)

func _on_stun_timeout():
	set_state(State.IDLE)

# --- Detection callbacks ---
func _on_detection_entered(body):
	if body.is_in_group(\"player\"):
		print(\"Cheetah: player spotted\")
		player = body
		if state == State.IDLE:
			set_state(State.STALKING)

func _on_detection_exited(body):
	if body.is_in_group(\"player\"):
		print(\"Cheetah: player left detection range\")
		player = null
		if state == State.STALKING:
			set_state(State.IDLE)

func _on_pounce_range_entered(body):
	if body.is_in_group(\"player\"):
		if state == State.STALKING:
			print(\"Cheetah: player in pounce range\")
			set_state(State.WINDUP)

# --- Central state manager ---
func set_state(new_state: State):
	state = new_state

	match new_state:
		State.IDLE:
			print(\"Cheetah: IDLE\")
			anim.play(\"idle\")

		State.STALKING:
			print(\"Cheetah: STALKING\")
			anim.play(\"stalking\")

		State.WINDUP:
			print(\"Cheetah: WINDUP\")
			windup_timer.wait_time = windup_time
			windup_timer.start()
			anim.play(\"windup\")

		State.POUNCING:
			print(\"Cheetah: POUNCING\")
			pounce_distance_traveled = 0.0
			anim.play(\"pouncing\")

		State.CHASING:
			print(\"Cheetah: CHASING\")
			stamina = max_stamina
			anim.play(\"chasing\")

# --- Debug Drawing ---
const DEBUG = true

func _process(_delta):
	if DEBUG:
		queue_redraw()

func _draw():
	if not DEBUG:
		return

	# outer detection circle
	draw_arc(Vector2.ZERO, detection_range, 0, TAU, 64, Color.YELLOW, 2.0)

	# inner pounce trigger circle
	draw_arc(Vector2.ZERO, pounce_trigger_range, 0, TAU, 64, Color.ORANGE, 2.0)

	# pounce direction during windup
	if state == State.WINDUP and player != null:
		var dir = (player.global_position - global_position).normalized()
		draw_dashed_line(Vector2.ZERO, dir * pounce_range, Color.RED, 2.0)

	# remaining pounce distance
	if state == State.POUNCING:
		var remaining = pounce_range - pounce_distance_traveled
		draw_line(Vector2.ZERO, pounce_direction * remaining, Color.RED, 3.0)

	# stamina bar above cheetah
	if state == State.CHASING:
		var bar_width = 60.0
		var stamina_pct = stamina / max_stamina
		draw_rect(Rect2(Vector2(-30, -50), Vector2(bar_width, 6)), Color.DARK_RED)
		draw_rect(Rect2(Vector2(-30, -50), Vector2(bar_width * stamina_pct, 6)), Color.GREEN)

	# state color dot
	var state_colors = {
		State.IDLE: Color.GRAY,
		State.STALKING: Color.YELLOW,
		State.WINDUP: Color.ORANGE,
		State.POUNCING: Color.RED,
		State.CHASING: Color.PURPLE
	}
	draw_arc(Vector2.ZERO, 6.0, 0, TAU, 16, state_colors[state], 3.0)
"

